# Copy to .env.local and fill in. Never commit .env.local.

# Cognito (optional — POC runs without login)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# DigitalOcean Spaces (S3-compatible object storage)
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=
SPACES_KEY=
SPACES_SECRET=

# DigitalOcean Gradient inference (OpenAI-compatible).
# Leave empty to use the built-in rule-based fallback stitcher.
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
DO_INFERENCE_API_KEY=
DO_INFERENCE_MODEL=llama3.3-70b-instruct

# ElevenLabs (optional — Web Speech API fallback used when empty)
ELEVENLABS_API_KEY=

# Gemini — video-based ASL recognition (preferred over frame sampling when set)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# DO Managed Valkey — TTS audio cache (optional; caching is best-effort)
VALKEY_URL=
