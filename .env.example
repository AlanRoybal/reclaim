# Copy to .env.local and fill in. Never commit .env.local.

# AWS Cognito + S3 (provision via AWS CLI — see README)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
AWS_REGION=us-east-1
S3_BUCKET=

# DigitalOcean Gradient inference (OpenAI-compatible).
# Leave empty to use the built-in rule-based fallback stitcher.
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
DO_INFERENCE_API_KEY=
DO_INFERENCE_MODEL=llama3.3-70b-instruct

# ElevenLabs (optional — Web Speech API fallback used when empty)
ELEVENLABS_API_KEY=

# Self-hosted F5-TTS voice service (services/f5-tts) — optional, tried before ElevenLabs
F5_TTS_URL=
F5_TTS_API_KEY=

# Vision model for AI-recognition mode (DO serverless slug)
DO_VISION_MODEL=llama-4-maverick
